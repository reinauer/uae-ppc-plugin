From 1b1cbfec41342e19ce0e87f324e08ec59233e15a Mon Sep 17 00:00:00 2001
From: Stefan Reinauer <stefan.reinauer@coreboot.org>
Date: Thu, 4 Jun 2026 22:40:50 -0700
Subject: [PATCH] uae: avoid QEMU 11 container helper

QEMU 9.2.4 has the container_get() helper needed to create or find a
container, but it does not have QEMU 11.0.1's
object_property_add_new_container() wrapper.

Use container_get() so the Win32 QEMU 9.2.4 build can use the same
machine setup logic without adding duplicate containers that QEMU 9's
machine_initfn() already created.
---
 uae/qemu-uae-main.c | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git a/uae/qemu-uae-main.c b/uae/qemu-uae-main.c
index 8520ba3f59..527817ae1c 100644
--- a/uae/qemu-uae-main.c
+++ b/uae/qemu-uae-main.c
@@ -74,6 +74,13 @@ static struct {
     bool exit_main_loop;
 } state;
 
+static Object *qemu_uae_add_new_container(Object *parent, const char *name)
+{
+    g_autofree char *path = g_strdup_printf("/%s", name);
+
+    return container_get(parent, path);
+}
+
 static bool qemu_uae_create_machine(void)
 {
     static const char *const containers[] = {
@@ -100,8 +107,7 @@ static bool qemu_uae_create_machine(void)
     object_property_add_child(object_get_root(), "machine",
                               OBJECT(current_machine));
     for (int i = 0; i < G_N_ELEMENTS(containers); i++) {
-        object_property_add_new_container(OBJECT(current_machine),
-                                          containers[i]);
+        qemu_uae_add_new_container(OBJECT(current_machine), containers[i]);
     }
     cpu_exec_init_all();
 
