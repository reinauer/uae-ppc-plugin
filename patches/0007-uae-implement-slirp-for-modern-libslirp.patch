-void slirp_output(void *opaque, const uint8_t *pkt, int pkt_len)
-{
-    uae_log("QEMU: slirp_output pkt_len %d\n", pkt_len);
-    if (uae_slirp_output == NULL) {
-        return;
-    }
-    uae_slirp_output(pkt, pkt_len);
-}
