@@ -82,6 +82,7 @@ esac
     --disable-numa \
     --disable-rdma \
     --disable-smartcard \
+    --disable-slirp \
     --disable-pie \
     --disable-vvfat \
     --disable-qed \
diff --git a/uae/qemu-uae-slirp.c b/uae/qemu-uae-slirp.c
index 6c4c96701..3a6f0a176 100644
--- a/uae/qemu-uae-slirp.c
+++ b/uae/qemu-uae-slirp.c
@@ -19,35 +19,295 @@
 
 #include "qemu/osdep.h"
