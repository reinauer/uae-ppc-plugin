From 43c467e3b90fdb23a9e6e700e35bf2925462b302 Mon Sep 17 00:00:00 2001
From: Stefan Reinauer <stefan.reinauer@coreboot.org>
Date: Thu, 4 Jun 2026 13:50:17 -0700
Subject: [PATCH 9/12] build: support Windows QEMU-UAE plugin output

Make the QEMU-UAE configure wrapper respect an existing MSYS2
compiler selection and prefer clang when it is available. The Windows
clang64 and clangarm64 environments need that path while the i686
MinGW32 environment can continue using GCC.

Select the shared-library suffix from the host OS so Windows builds
produce qemu-uae.dll and Unix/macOS builds keep qemu-uae.so.

Mark exported callback storage declarations with matching data export
attributes so Windows clang accepts the exported definitions.
---
 README.md          |  6 ++++--
 configure-qemu-uae | 18 +++++++++++++++---
 meson.build        |  3 ++-
 uae/api.h          |  5 +++++
 uae/log.h          |  2 +-
 uae/ppc.h          | 10 ++++++----
 6 files changed, 33 insertions(+), 11 deletions(-)

diff --git a/README.md b/README.md
index bb8e4f4788..286700efbd 100644
--- a/README.md
+++ b/README.md
@@ -26,14 +26,16 @@ cd build
 ninja
 ```
 
-The shared library will be created at `build/qemu-uae.so`.
+The shared library will be created as `build/qemu-uae.so` on Unix
+hosts or `build/qemu-uae.dll` on Windows hosts.
 
 ### Build Options
 
 The `configure-qemu-uae` script configures QEMU with minimal features required for UAE:
 
 - Target: `ppc-softmmu` only
-- Builds as shared library (`qemu-uae.so`) instead of executable
+- Builds as shared library (`qemu-uae.so` or `qemu-uae.dll`) instead
+  of executable
 - Disables unnecessary features (SDL, GTK, VNC, KVM, etc.)
 
 Debug options can be enabled by uncommenting lines in `configure-qemu-uae`:
diff --git a/configure-qemu-uae b/configure-qemu-uae
index 43a5a2f277..ad9212c452 100755
--- a/configure-qemu-uae
+++ b/configure-qemu-uae
@@ -15,9 +15,21 @@ EXTRA_CFLAGS="-DDEBUG_UNASSIGNED"
 
 OS_NAME=$(uname -s)
 case $OS_NAME in
-MINGW*|MSYS*)
-    export CC=gcc
-    export CXX=g++
+MINGW*|MSYS*|CLANG*|UCRT*)
+    if [ -z "${CC:-}" ]; then
+        if command -v clang >/dev/null 2>&1; then
+            export CC=clang
+        else
+            export CC=gcc
+        fi
+    fi
+    if [ -z "${CXX:-}" ]; then
+        if command -v clang++ >/dev/null 2>&1; then
+            export CXX=clang++
+        else
+            export CXX=g++
+        fi
+    fi
     ;;
 *)
     EXTRA_CFLAGS="$EXTRA_CFLAGS -fPIC"
diff --git a/meson.build b/meson.build
index dd90b1647a..ed5bc88f42 100644
--- a/meson.build
+++ b/meson.build
@@ -4452,6 +4452,7 @@ foreach target : target_dirs
     if get_option('qemu_uae') and target_name == 'ppc'
       qemu_uae_link_args = []
       qemu_uae_link_depends = [block_syms, qemu_syms]
+      qemu_uae_suffix = host_os == 'windows' ? 'dll' : 'so'
       if host_os == 'darwin'
         qemu_uae_exports = files('uae/qemu-uae-ld64.symbols')
         qemu_uae_link_depends += qemu_uae_exports
@@ -4471,7 +4472,7 @@ foreach target : target_dirs
                  link_depends: qemu_uae_link_depends,
                  link_args: qemu_uae_link_args,
                  name_prefix: '',
-                 name_suffix: 'so')
+                 name_suffix: qemu_uae_suffix)
       emulators += {'qemu-uae': emulator}
       # Also add qemu-system-ppc alias for test compatibility
       emulators += {'qemu-system-ppc': emulator}
diff --git a/uae/api.h b/uae/api.h
index fdbc4acb50..b87dec8431 100644
--- a/uae/api.h
+++ b/uae/api.h
@@ -19,8 +19,10 @@
 
 #ifdef __cplusplus
 #define UAE_EXTERN_C extern "C"
+#define UAE_EXTERN_C_DATA extern "C"
 #else
 #define UAE_EXTERN_C
+#define UAE_EXTERN_C_DATA extern
 #endif
 
 /* UAE_EXPORT / UAE_IMPORT are mainly intended as helpers for UAEAPI
@@ -34,6 +36,9 @@
 #define UAE_IMPORT
 #endif
 
+#define UAE_EXPORT_DATA UAE_EXTERN_C_DATA UAE_EXPORT
+#define UAE_IMPORT_DATA UAE_EXTERN_C_DATA UAE_IMPORT
+
 /* UAEAPI marks a function for export across library boundaries. You'll
  * likely want to use this together with UAECALL. */
 
diff --git a/uae/log.h b/uae/log.h
index 83b7a0fd72..4424a7a0eb 100644
--- a/uae/log.h
+++ b/uae/log.h
@@ -21,7 +21,7 @@ typedef void (UAECALL *uae_log_function)(const char *format, ...) UAE_PRINTF_FOR
 //UAEAPI void UAECALL uae_log(const char *format, ...) UAE_PRINTF_FORMAT(1, 2);
 void UAECALL uae_log(const char *format, ...) UAE_PRINTF_FORMAT(1, 2);
 #else
-extern uae_log_function uae_log;
+UAE_EXPORT_DATA uae_log_function uae_log;
 #endif
 
 #ifdef FSUAE // NL
diff --git a/uae/ppc.h b/uae/ppc.h
index 41a085d516..0e82e5e020 100644
--- a/uae/ppc.h
+++ b/uae/ppc.h
@@ -17,8 +17,10 @@
 
 #ifdef UAE
 #define PPCAPI UAE_EXTERN_C UAE_IMPORT
+#define PPCDATA UAE_IMPORT_DATA
 #else
 #define PPCAPI UAE_EXTERN_C UAE_EXPORT
+#define PPCDATA UAE_EXPORT_DATA
 #endif
 #define PPCCALL UAECALL
 
@@ -84,10 +86,10 @@ bool UAECALL uae_ppc_io_mem_write64(uint32_t addr, uint64_t data);
 
 #else
 
-extern uae_ppc_io_mem_read_function uae_ppc_io_mem_read;
-extern uae_ppc_io_mem_write_function uae_ppc_io_mem_write;
-extern uae_ppc_io_mem_read64_function uae_ppc_io_mem_read64;
-extern uae_ppc_io_mem_write64_function uae_ppc_io_mem_write64;
+PPCDATA uae_ppc_io_mem_read_function uae_ppc_io_mem_read;
+PPCDATA uae_ppc_io_mem_write_function uae_ppc_io_mem_write;
+PPCDATA uae_ppc_io_mem_read64_function uae_ppc_io_mem_read64;
+PPCDATA uae_ppc_io_mem_write64_function uae_ppc_io_mem_write64;
 
 #endif
 
