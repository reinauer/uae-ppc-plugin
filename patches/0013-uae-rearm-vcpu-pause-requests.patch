From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Stefan Reinauer <stefan.reinauer@coreboot.org>
Date: Mon, 6 Jul 2026 20:30:00 -0700
Subject: [PATCH 13/13] uae: re-arm vCPU pause requests

pause_all_vcpus() issues the stop request once and then waits on
qemu_pause_cond without a timeout; the retry loop only re-kicks the
vCPUs, it never re-issues the request, and cpu_resume() clears it
unconditionally. WinUAE can trigger exactly that race: a PPC-initiated
CSPPC reboot (guest CSIII_REG_RESET write, executed on the vCPU thread)
calls resume while the emulation thread's quit/pause request is in
flight, permanently cancelling it. The pauser then waits forever inside
ppc_cpu_set_state(PPC_CPU_STATE_PAUSED) - the long-standing random
"quit hangs during OS4 boot" seen with both the QEMU 9 and QEMU 11
based plugins.

Pause through a re-arming loop instead: re-issue the stop request until
every vCPU has really stopped, releasing the BQL between polls so the
vCPUs can finish in-flight MMIO and park. Self-pause from the vCPU
thread keeps the stock pause_all_vcpus() semantics. Also log after the
BQL is acquired so the two possible blocking points (lock acquisition
vs pause wait) are distinguishable in user logs.
---

 uae/qemu-uae-cpu.c | 58 ++++++++++++++++++++++++++++++++++++++++++++++++++++--
 1 file changed, 56 insertions(+), 2 deletions(-)

--- a/uae/qemu-uae-cpu.c
+++ b/uae/qemu-uae-cpu.c
@@ -21,6 +21,7 @@
 #include "qemu/log.h"
 #include "qemu/module.h"
 #include "qemu/atomic.h"
+#include "qemu/timer.h"
 #include "qapi/error.h"
 #include "hw/ppc/ppc.h"
 #include "hw/core/boards.h"
@@ -399,12 +400,66 @@
     cpu_dump_state(CPU(state.cpu), stderr, flags);
 }
 
+static bool qemu_uae_all_vcpus_paused(void)
+{
+    CPUState *cpu;
+
+    CPU_FOREACH(cpu) {
+        if (!cpu->stopped) {
+            return false;
+        }
+    }
+    return true;
+}
+
+/* pause_all_vcpus() issues the stop request once and then waits without a
+ * timeout; a concurrent resume_all_vcpus() (a PPC-initiated reboot racing
+ * a WinUAE pause or quit) clears the request and the wait never finishes.
+ * This variant re-arms the request until every vCPU has really stopped.
+ * Must be called with the BQL held, from outside the vCPU thread. */
+static void qemu_uae_pause_all_vcpus(void)
+{
+    CPUState *cpu;
+    int waited_ms = 0;
+
+    qemu_clock_enable(QEMU_CLOCK_VIRTUAL, false);
+    CPU_FOREACH(cpu) {
+        cpu->stop = true;
+        cpu_exit(cpu);
+    }
+    while (!qemu_uae_all_vcpus_paused()) {
+        qemu_uae_mutex_unlock();
+        g_usleep(2000);
+        qemu_uae_mutex_lock();
+        waited_ms += 2;
+        CPU_FOREACH(cpu) {
+            if (!cpu->stopped) {
+                if (!cpu->stop) {
+                    uae_log("QEMU: pause request was cancelled, re-arming\n");
+                    cpu->stop = true;
+                }
+                cpu_exit(cpu);
+            }
+        }
+        if (waited_ms % 1000 == 0) {
+            uae_log("QEMU: still waiting for vCPU pause (%d ms)\n", waited_ms);
+        }
+    }
+}
+
 void PPCAPI ppc_cpu_set_state(int set_state)
 {
     uae_log("QEMU: Set state %d\n", set_state);
     qemu_uae_lock_if_needed();
+    uae_log("QEMU: Set state %d (lock acquired)\n", set_state);
     if (set_state == PPC_CPU_STATE_PAUSED) {
-        pause_all_vcpus();
+        if (qemu_uae_ppc_in_cpu_thread()) {
+            /* Self-pause: the single vCPU marks itself stopped and
+             * returns without waiting; stock semantics are safe. */
+            pause_all_vcpus();
+        } else {
+            qemu_uae_pause_all_vcpus();
+        }
         state.cpu_state = PPC_CPU_STATE_PAUSED;
         uae_log("QEMU: Paused!\n");
         qemu_uae_log_cpu_state();
-- 
